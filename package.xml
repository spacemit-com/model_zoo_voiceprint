<?xml version="1.0"?>
<package format="3">
  <name>voiceprint</name>
  <version>0.1.0</version>
  <description>Speaker recognition using ONNX Runtime</description>
  <system_depend check="pkg-config --exists libcurl">libcurl4-openssl-dev</system_depend>
