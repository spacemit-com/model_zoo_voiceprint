<?xml version="1.0"?>
<package format="3">
  <name>voiceprint</name>
  <version>0.1.0</version>
  <description>Speaker recognition using ONNX Runtime</description>
  <system_depend check="pkg-config --exists libcurl">libcurl4-openssl-dev</system_depend>
  <system_depend check="pkg-config --exists alsa">libasound2-dev</system_depend>
  <system_depend check="command -v git">git</system_depend>
  <system_depend arch="riscv64">spacemit-onnxruntime</system_depend>
  <system_depend arch="riscv64">python3-spacemit-ort</system_depend>

  <export>
    <build_type>cmake</build_type>
  </export>
</package>
